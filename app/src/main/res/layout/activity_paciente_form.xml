<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_paciente_form.xml — Formulario para CREAR o EDITAR un paciente (vista 5)

    Uso NestedScrollView para que el formulario sea scrolleable cuando el teclado
    aparece y empuja todo hacia arriba. Sin esto, los campos del final quedarían tapados.
    Adentro va un ConstraintLayout con todos los campos.
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PacienteFormActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Título dinámico: cambia entre "Nuevo Paciente" y "Editar Paciente" desde el código -->
        <TextView
            android:id="@+id/tvTituloForm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Nuevo Paciente"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/purple_700"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!--
            TextInputLayout + TextInputEditText = pareja de Material Design.
            TextInputLayout es el contenedor que muestra el hint flotante y los errores.
            TextInputEditText es donde el usuario escribe.
            El asterisco * en el hint indica que el campo es obligatorio.
        -->

        <!-- Campo: Nombre del paciente -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNombre"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Nombre *"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTituloForm">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Apellido del paciente -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilApellido"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Apellido *"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilNombre">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etApellido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Fecha de nacimiento (formato libre dd/mm/aaaa) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilFechaNacimiento"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Fecha de nacimiento (dd/mm/aaaa) *"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilApellido">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFechaNacimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="datetime" />
        </com.google.android.material.textfield.TextInputLayout>

        <!--
            Peso y estatura van LADO A LADO en la misma fila.
            Por eso uso layout_width="0dp" y los constraintEnd/Start apuntando uno al otro.
            layout_marginEnd/Start de 8dp crea el espacio entre los dos campos.
        -->

        <!-- Campo: Peso en kilogramos -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPeso"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:hint="Peso (kg) *"
            app:layout_constraintEnd_toStartOf="@id/tilEstatura"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilFechaNacimiento">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPeso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Estatura en metros (ej: 1.70) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEstatura"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="8dp"
            android:hint="Estatura (m) *"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tilPeso"
            app:layout_constraintTop_toBottomOf="@id/tilFechaNacimiento">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEstatura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <!--
            Campo IMC: es de solo lectura (focusable="false", inputType="none").
            El valor lo calcula y escribe el TextWatcher automáticamente cuando
            cambio peso o estatura. El usuario no puede editarlo directamente.
        -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilImc"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="IMC (calculado automáticamente)"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilPeso">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etImc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:inputType="none"
                android:textColor="@color/purple_500" />
        </com.google.android.material.textfield.TextInputLayout>

        <!--
            Campo multilinea para antecedentes médicos.
            minLines="3" lo hace un poco más alto visualmente, útil para texto largo.
            No es obligatorio (no tiene asterisco ni validación en el código).
        -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAntecedentes"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Antecedentes médicos"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilImc">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAntecedentes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Estado del paciente. Si lo dejo vacío, el código pone "EN_ESPERA" por defecto -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEstado"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Estado (EN_ESPERA / EN_CONSULTA / ALTA)"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilAntecedentes">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Botón que llama a guardarPaciente() en el Activity (valida y guarda) -->
        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Guardar Paciente"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilEstado" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
